{
  "permissionMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(npm test *)",
      "Bash(npm run test *)",
      "Bash(pytest *)"
    ],
    "deny": [
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(zsh *)",
      "Bash(fish *)",
      "Bash(python *)",
      "Bash(node -e *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(sudo *)",
      "Bash(doas *)",
      "Bash(npm install *)",
      "Bash(pip install *)"
    ]
  }
}
